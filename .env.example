# Скопируй этот файл в .env и заполни значения.
# .env в .gitignore — реальные ключи НИКОГДА не попадают в репозиторий.
# На Hugging Face Spaces эти же переменные заводятся через Settings → Secrets.

# Обязательно: ключ OpenAI для Agents SDK
OPENAI_API_KEY=sk-...

# Опционально: email-отправка (в деплое не используется — галочка без реальной отправки).
# Оставь пустым, если не настраиваешь SendGrid локально.
SENDGRID_API_KEY=

# Опционально: адреса для email-агента. Хардкодить адреса запрещено (RULES §5).
# Если не заданы — в коде используются заглушки example.com.
EMAIL_FROM=
EMAIL_TO=
